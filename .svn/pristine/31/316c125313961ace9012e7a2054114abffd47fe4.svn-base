// ── News ─────────────────────────────────────────────────
exports.newsService = {
    async getAll(filters) {
        const page = Math.max(1, filters.page || 1);
        const limit = Math.min(50, Math.max(1, filters.limit || 10));
        const skip = (page - 1) * limit;
        const where = { isPublished: true };
        if (filters.tag)
            where.tags = { has: filters.tag };
        const [articles, total] = await Promise.all([
            database_1.prisma.news.findMany({
                where,
                orderBy: { publishedAt: 'desc' },
                skip,
                take: limit,
            }),
            database_1.prisma.news.count({ where }),
        ]);
        return { articles, pagination: { page, limit, total, totalPages: Math.ceil(total / limit) } };
    },
    async getAllAdmin(filters) {
        const page = Math.max(1, filters.page || 1);
        const limit = Math.min(100, Math.max(1, filters.limit || 20));
        const skip = (page - 1) * limit;
        const where = {};
        if (filters.tag)
            where.tags = { has: filters.tag };
        const [articles, total] = await Promise.all([
            database_1.prisma.news.findMany({
                where,
                orderBy: [{ createdAt: 'desc' }, { publishedAt: 'desc' }],
                skip,
                take: limit,
            }),
            database_1.prisma.news.count({ where }),
        ]);
        return { articles, pagination: { page, limit, total, totalPages: Math.ceil(total / limit) } };
    },
    async getAllAdmin(filters) {
        const page = Math.max(1, filters.page || 1);
        const limit = Math.min(100, Math.max(1, filters.limit || 20));
        const skip = (page - 1) * limit;
        const where = {};
        if (filters.tag)
            where.tags = { has: filters.tag };
        const [articles, total] = await Promise.all([
            database_1.prisma.news.findMany({
                where,
                orderBy: [{ createdAt: 'desc' }, { publishedAt: 'desc' }],
                skip,
                take: limit,
            }),
            database_1.prisma.news.count({ where }),
        ]);
        return { articles, pagination: { page, limit, total, totalPages: Math.ceil(total / limit) } };
    },
    async getBySlug(slug) {
        const article = await database_1.prisma.news.findUnique({ where: { slug } });
        if (!article)
            throw new error_middleware_1.AppError(404, 'Article not found');
        // Increment view count
        await database_1.prisma.news.update({ where: { id: article.id }, data: { viewCount: { increment: 1 } } });
        return article;
    },
    async create(data) {
        return database_1.prisma.news.create({ data });
    },
    async update(id, data) {
        return database_1.prisma.news.update({ where: { id }, data });
    },
    async delete(id) {
        await database_1.prisma.news.delete({ where: { id } });
        return { message: 'Article deleted' };
    },
};
