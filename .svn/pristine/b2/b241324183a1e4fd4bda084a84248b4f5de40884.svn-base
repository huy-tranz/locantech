const product_service_1 = require("@/services/product.service");
const getAll = async (req, res, next) => {
    try {
        const result = await product_service_1.productService.getAll(req.query);
        res.json(result);
    }
    catch (err) {
        next(err);
    }
};
exports.getAll = getAll;
const getById = async (req, res, next) => {
    try {
        const product = await product_service_1.productService.getById(req.params.id);
        res.json(product);
    }
    catch (err) {
        next(err);
    }
};
exports.getById = getById;
const getBySlug = async (req, res, next) => {
    try {
        const product = await product_service_1.productService.getBySlug(req.params.slug);
        res.json(product);
    }
    catch (err) {
        next(err);
    }
};
exports.getBySlug = getBySlug;
const getFeatured = async (req, res, next) => {
    try {
        const products = await product_service_1.productService.getFeatured(Number(req.query.limit) || 8);
        res.json(products);
    }
    catch (err) {
        next(err);
    }
};
exports.getFeatured = getFeatured;
const getBestSellers = async (req, res, next) => {
    try {
        const products = await product_service_1.productService.getBestSellers(Number(req.query.limit) || 8);
        res.json(products);
    }
    catch (err) {
        next(err);
    }
};
exports.getBestSellers = getBestSellers;
const getRelated = async (req, res, next) => {
    try {
        const products = await product_service_1.productService.getRelated(req.params.id, Number(req.query.limit) || 4);
        res.json(products);
    }
    catch (err) {
        next(err);
    }
};
exports.getRelated = getRelated;
const getBrands = async (_req, res, next) => {
    try {
        const brands = await product_service_1.productService.getBrands();
        res.json(brands);
    }
    catch (err) {
        next(err);
    }
};
exports.getBrands = getBrands;
// Admin
const create = async (req, res, next) => {
    try {
        const product = await product_service_1.productService.create(req.body);
        res.status(201).json(product);
    }
    catch (err) {
        next(err);
    }
};
exports.create = create;
const update = async (req, res, next) => {
    try {
        const product = await product_service_1.productService.update(req.params.id, req.body);
        res.json(product);
    }
    catch (err) {
        next(err);
    }
};
exports.update = update;
const remove = async (req, res, next) => {
    try {
        const result = await product_service_1.productService.delete(req.params.id);
        res.json(result);
    }
    catch (err) {
        next(err);
    }
};
exports.remove = remove;
