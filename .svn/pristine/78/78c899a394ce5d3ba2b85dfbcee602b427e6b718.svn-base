@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --background: 210 20% 98%;
    --foreground: 215 25% 15%;

    --card: 0 0% 100%;
    --card-foreground: 215 25% 15%;

    --popover: 0 0% 100%;
    --popover-foreground: 215 25% 15%;

    --primary: 213 70% 28%;
    --primary-foreground: 0 0% 100%;

    --primary-light: 213 60% 45%;
    --primary-dark: 213 80% 18%;

    --secondary: 210 15% 93%;
    --secondary-foreground: 215 25% 20%;

    --muted: 210 15% 95%;
    --muted-foreground: 215 10% 50%;

    --accent: 20 90% 52%;
    --accent-foreground: 0 0% 100%;

    --accent-hover: 20 95% 45%;

    --sale: 0 80% 55%;
    --sale-foreground: 0 0% 100%;

    --success: 145 60% 40%;
    --success-foreground: 0 0% 100%;

    --warning: 40 90% 55%;
    --warning-foreground: 215 25% 15%;

    --destructive: 0 84% 60%;
    --destructive-foreground: 0 0% 100%;

    --border: 214 20% 90%;
    --input: 214 20% 90%;
    --ring: 213 70% 28%;

    --radius: 0.5rem;

    --sidebar-background: 0 0% 98%;
    --sidebar-foreground: 240 5.3% 26.1%;
    --sidebar-primary: 240 5.9% 10%;
    --sidebar-primary-foreground: 0 0% 98%;
    --sidebar-accent: 240 4.8% 95.9%;
    --sidebar-accent-foreground: 240 5.9% 10%;
    --sidebar-border: 220 13% 91%;
    --sidebar-ring: 217.2 91.2% 59.8%;

    --header-gradient: linear-gradient(135deg, hsl(213 80% 18%), hsl(213 70% 28%));
    --shadow-card: 0 2px 8px hsl(215 25% 15% / 0.08);
    --shadow-card-hover: 0 8px 24px hsl(215 25% 15% / 0.12);
    --shadow-header: 0 2px 12px hsl(215 25% 15% / 0.1);
  }

  .dark {
    --background: 215 25% 10%;
    --foreground: 210 20% 95%;
    --card: 215 25% 13%;
    --card-foreground: 210 20% 95%;
    --popover: 215 25% 13%;
    --popover-foreground: 210 20% 95%;
    --primary: 213 60% 50%;
    --primary-foreground: 0 0% 100%;
    --secondary: 217 20% 18%;
    --secondary-foreground: 210 20% 90%;
    --muted: 217 20% 18%;
    --muted-foreground: 215 15% 60%;
    --accent: 20 90% 52%;
    --accent-foreground: 0 0% 100%;
    --destructive: 0 62% 30%;
    --destructive-foreground: 210 20% 95%;
    --border: 217 20% 22%;
    --input: 217 20% 22%;
    --ring: 213 60% 50%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground font-sans;
    font-family: 'Be Vietnam Pro', sans-serif;
  }

  html {
    scroll-behavior: smooth;
  }
}

@layer components {
  .section-container {
    @apply max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8;
  }

  .product-price {
    @apply text-lg font-bold;
    color: hsl(var(--sale));
  }

  .product-price-old {
    @apply text-sm line-through;
    color: hsl(var(--muted-foreground));
  }

  .badge-sale {
    @apply inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold;
    background: hsl(var(--sale));
    color: hsl(var(--sale-foreground));
  }

  .badge-new {
    @apply inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold;
    background: hsl(var(--success));
    color: hsl(var(--success-foreground));
  }

  .badge-hot {
    @apply inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold;
    background: hsl(var(--accent));
    color: hsl(var(--accent-foreground));
  }

  .btn-cta {
    @apply inline-flex items-center justify-center px-5 py-2.5 rounded-lg font-semibold text-sm transition-all duration-200;
    background: hsl(var(--accent));
    color: hsl(var(--accent-foreground));
  }
  .btn-cta:hover {
    background: hsl(var(--accent-hover));
    transform: translateY(-1px);
    box-shadow: 0 4px 12px hsl(var(--accent) / 0.3);
  }

  .btn-primary {
    @apply inline-flex items-center justify-center px-5 py-2.5 rounded-lg font-semibold text-sm transition-all duration-200;
    background: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
  }
  .btn-primary:hover {
    background: hsl(var(--primary-light));
  }

  .header-bg {
    background: var(--header-gradient);
  }

  .card-product {
    @apply bg-card rounded-lg border overflow-hidden transition-all duration-200;
    box-shadow: var(--shadow-card);
  }
  .card-product:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .shadow-header {
    box-shadow: var(--shadow-header);
  }
}
