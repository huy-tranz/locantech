const getNews = async (req, res, next) => {
    try {
        const result = await cms_service_1.newsService.getAll({
            page: Number(req.query.page) || 1,
            limit: Number(req.query.limit) || 10,
            tag: req.query.tag,
        });
        res.json(result);
    }
    catch (err) {
        next(err);
    }
};
