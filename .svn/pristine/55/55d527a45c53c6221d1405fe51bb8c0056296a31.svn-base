const database_1 = require("@/config/database");
/**
 * Generate a human-readable order number
 * Format: LA-YYYYMMDD-XXX (e.g., LA-20260324-001)
 */
const generateOrderNumber = async () => {
    const today = new Date();
    const dateStr = today.toISOString().slice(0, 10).replace(/-/g, ''); // YYYYMMDD
    const prefix = `LA-${dateStr}-`;
    // Count orders today
    const count = await database_1.prisma.order.count({
        where: {
            orderNumber: {
                startsWith: prefix,
            },
        },
    });
    const seq = String(count + 1).padStart(3, '0');
    return `${prefix}${seq}`;
};
exports.generateOrderNumber = generateOrderNumber;
/**
 * Generate a repair ticket number
 * Format: REP-YYYYMMDD-XXX (e.g., REP-20260324-001)
 */
const generateTicketNumber = async () => {
    const today = new Date();
    const dateStr = today.toISOString().slice(0, 10).replace(/-/g, '');
    const prefix = `REP-${dateStr}-`;
    const count = await database_1.prisma.repairRequest.count({
        where: {
            ticketNumber: {
                startsWith: prefix,
            },
        },
    });
    const seq = String(count + 1).padStart(3, '0');
    return `${prefix}${seq}`;
};
exports.generateTicketNumber = generateTicketNumber;
